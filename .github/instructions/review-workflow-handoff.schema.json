{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wodansson.github.io/terraform-azurerm-ai-assisted-development/.github/instructions/review-workflow-handoff.schema.json",
  "title": "Review Workflow Handoff Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "roles",
    "title",
    "scope",
    "severity",
    "evidence",
    "reasoning",
    "confidence",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/role"
      }
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "lines": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "severity": {
      "type": "string",
      "enum": [
        "critical",
        "high",
        "medium",
        "low",
        "observation"
      ]
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/evidenceItem"
      }
    },
    "reasoning": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "candidate",
        "observation",
        "confirmed",
        "downgraded",
        "dismissed"
      ]
    },
    "ruleReferences": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "roleNotes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/roleNote"
      }
    }
  },
  "$defs": {
    "role": {
      "type": "string",
      "enum": [
        "reviewer",
        "review-architect",
        "review-skeptic",
        "review-advocate",
        "moderator"
      ]
    },
    "evidenceItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "value"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "file",
            "diff",
            "tool",
            "comment",
            "pattern",
            "external"
          ]
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "roleNote": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "kind",
        "summary"
      ],
      "properties": {
        "role": {
          "$ref": "#/$defs/role"
        },
        "kind": {
          "type": "string",
          "enum": [
            "finding",
            "direction",
            "challenge",
            "defense",
            "adjudication",
            "status-change"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
